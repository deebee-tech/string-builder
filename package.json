{
  "name": "@deebeetech/string-builder",
  "version": "2.0.4",
  "description": "A lightweight, chainable string builder for TypeScript and JavaScript. Inspired by builders in C#, Java, and Go — intended for small collections of strings, not extremely large buffers.",
  "homepage": "https://github.com/deebee-tech/string-builder",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "Sandy Weatherby",
    "email": "unicornbeachdiaries@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deebee-tech/string-builder"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "dist/index.d.cts",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "string",
    "builder",
    "stringbuilder",
    "string-builder",
    "string builder",
    "concatenation",
    "concat",
    "concatenate",
    "typescript",
    "javascript",
    "ts",
    "js"
  ],
  "scripts": {
    "build": "tsdown && node ./scripts/prepare-dist.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "spell": "cspell --no-progress \"**\"",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify-dist": "node ./scripts/verify-dist.mjs"
  },
  "packageManager": "pnpm@11.13.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sebbo2002/semantic-release-jsr": "^4.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "cspell": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.7",
    "semantic-release-replace-plugin": "^1.2.7",
    "tsdown": "^0.22.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
