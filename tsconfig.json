{
   "compilerOptions": {
      "target": "ESNext",
      "lib": ["ESNext"],
      "module": "ESNext",
      "moduleResolution": "bundler",
      "declaration": true,
      "sourceMap": true,
      "outDir": "./dist",
      "forceConsistentCasingInFileNames": true,
      "strict": true,
      "skipLibCheck": true
   }
}
